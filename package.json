{
  "type": "module",
  "dependencies": {
    "playwright-core": "^1.58.0"
  },
  "scripts": {
    "preinstall": "node -e \"if(!/pnpm/.test(process.env.npm_config_user_agent||'')){console.error('This repo uses pnpm only. Use: pnpm install');process.exit(1)}\"",
    "start": "python scrap_sns_server.py",
    "view": "wscript sns_hub.vbs",
    "stop": "stop_viewer.bat",
    "scrap:threads": "python thread_scrap.py",
    "scrap:linkedin": "python linkedin_scrap.py",
    "scrap:all": "python total_scrap.py",
    "cleanup:outputs": "node scripts/cleanup_old_output_json.mjs --dry-run",
    "cleanup:outputs:apply": "node scripts/cleanup_old_output_json.mjs --apply"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.11",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  },
  "packageManager": "pnpm@11.0.9"
}
